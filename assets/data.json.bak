    {
      "id": "auto-346",
      "subject_id": "other",
      "chapter_id": "ch14",
      "category_id": "concept",
      "title": "Bản chất của hình ảnh và phép tích chập (Chương 14)",
      "content": "\\end{tcolorbox}\r\n\n\n\n\n\\section{Ma trận trong xử lý ảnh (Thị giác máy tính)}\r\n\n\\begin{tcolorbox}[\r\ntitle={Bản chất của hình ảnh và phép tích chập},\r\nfonttitle=\\bfseries,\r\ncolback=gray!10, \r\ncolframe=black!70, \r\nboxrule=1pt, \r\narc=3mm, \r\nauto outer arc, \r\nleft=5pt, right=5pt, top=5pt, bottom=5pt\r\n]",
      "tags": [
        "bản chất của hình ảnh và phép tích chập"
      ],
      "related_ids": []
